# --- Vercel (Production / Preview) — set these in Project → Settings → Environment Variables ---
#
# Postgres: Prisma Postgres (direct URL, often host db.prisma.io), Neon, Supabase, or Vercel Postgres.
# For Prisma ORM, paste the same direct URL as POSTGRES_URL or PRISMA_DATABASE_URL (not Accelerate).
POSTGRES_URL=postgres://user:password@host:5432/dbname?sslmode=require
# PRISMA_DATABASE_URL=postgres://…  # optional: Prisma dashboard / env name (used if POSTGRES_URL unset)
# DATABASE_URL=

# Same value in Vercel env + typed on /admin/waitlist as Bearer token (long random string).
WAITLIST_EXPORT_TOKEN=replace_with_long_random_token

# If waitlist APIs 500 on Vercel but your DB is Neon, set to 1 so the HTTP driver is used even if the hostname is unusual.
# UCHRAL_USE_NEON_HTTP=1

# NEVER set in Vercel Production. Optional: local `vercel dev` only — allows GET /api/waitlist-admin
# without Authorization when request includes header X-Uchral-Admin-Dev: 1 (the dev-only button sends this).
UCHRAL_ADMIN_DEV_BYPASS=1

# Optional — local dev: proxy /api to a deployed app so waitlist hits real DB.
# VITE_DEV_API_ORIGIN=https://your-app.vercel.app
