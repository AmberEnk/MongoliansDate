# --- Vercel (Production / Preview) — set these in Project → Settings → Environment Variables ---
#
# Postgres: use Vercel Postgres "POSTGRES_URL", or Neon/Supabase "DATABASE_URL".
# Include sslmode=require (or your host’s recommended SSL params).
POSTGRES_URL=postgres://user:password@host:5432/dbname?sslmode=require
# DATABASE_URL=

# Same value in Vercel env + typed on /admin/waitlist as Bearer token (long random string).
WAITLIST_EXPORT_TOKEN=replace_with_long_random_token

# Optional — local dev: proxy /api to a deployed app so waitlist hits real DB.
# VITE_DEV_API_ORIGIN=https://your-app.vercel.app
