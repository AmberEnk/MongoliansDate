{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/ping.ts": { "runtime": "nodejs20.x", "maxDuration": 30 },
    "api/waitlist.ts": { "runtime": "nodejs20.x", "maxDuration": 30, "memory": 1024 },
    "api/waitlist-admin.ts": { "runtime": "nodejs20.x", "maxDuration": 30, "memory": 1024 },
    "api/waitlist-export.ts": { "runtime": "nodejs20.x", "maxDuration": 30, "memory": 1024 }
  },
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
